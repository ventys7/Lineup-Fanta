{
  "name": "lineup-fanta",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "npm --prefix dashboard run build",
    "typecheck": "npm --prefix dashboard run typecheck",
    "test": "node --test tests/*.test.cjs",
    "diagnose": "node scripts/diagnose.mjs",
    "verify": "npm run diagnose && npm run test && npm run build && node scripts/generate-route-pages.mjs && ./scripts/check-static.sh && git diff --check"
  },
  "dependencies": {
    "@vercel/blob": "2.6.1"
  }
}
